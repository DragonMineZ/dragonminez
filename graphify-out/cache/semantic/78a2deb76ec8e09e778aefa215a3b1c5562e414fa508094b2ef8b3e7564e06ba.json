{"nodes": [{"id": "patch_notes_patch_notes_v2_1_1_release_notes", "label": "Patch Notes v2.1.1", "file_type": "document", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "patch_notes_patch_notes_v2_1_1_defense_system_rework", "label": "Defense System Rework (Flat Mitigation Units)", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Defense stored as flat mitigation units so the displayed value directly represents damage reduction per hit; existing worlds auto-migrate at config 21.2 by multiplying defenseScaling by 0.12; the old transform DEF divider was removed in favor of higher per-form defMultiplier values."}, {"id": "patch_notes_patch_notes_v2_1_1_adaptive_defense_mitigation", "label": "Adaptive Defense Mitigation", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A final proportional reduction layer strongest at damage-to-defense parity, decaying as damage exceeds defense (default cap 70%); hits are fully negated when flat mitigation reaches 3x incoming damage."}, {"id": "patch_notes_patch_notes_v2_1_1_quest_rewards_per_difficulty", "label": "Quest Rewards Per Difficulty (JSON difficulty field)", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Shipped as a developer/operator framework feature not applied to default quests until v2.2, letting addon authors gate rewards by difficulty ahead of official content."}, {"id": "patch_notes_patch_notes_v2_1_1_transformation_stat_overrides", "label": "Quest-Tunable Transformation Stats (Transform* fields)", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Absolute overrides take precedence over multipliers; a transformDefaults block in entities.json sets global defaults that per-quest overrides always win over."}, {"id": "patch_notes_patch_notes_v2_1_1_form_tint_config", "label": "Form Skin Tint Config (tintColor/tintIntensity)", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Replaces the old hardcoded Kaioken-only red tint with a generic per-form JSON config; user-defined form files are automatically version-migrated on load."}, {"id": "patch_notes_patch_notes_v2_1_1_structure_spawn_planner_overhaul", "label": "Structure Spawn Planning Overhaul (dragonminez_structure_plan)", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Structure positions are resolved once and saved to world data so later starts skip the biome search; the overworld resolves synchronously at first world creation so near-spawn structures exist before the first spawn chunk generates."}, {"id": "patch_notes_patch_notes_v2_1_1_tp_multiplier_fix", "label": "TP Multiplier Additive Combination Fix", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All TP bonuses are now combined additively (total = 1 + sum(bonus - 1)) because multiplicative stacking of several sources compounded and overstated TP gains; the HTC default multiplier was reduced from 2.5x to 1.75x as part of the same rebalance."}, {"id": "patch_notes_patch_notes_v2_1_1_gravity_weight_rework", "label": "Gravity and Weight System Rework (GravityStateSync)", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "patch_notes_patch_notes_v2_1_1_smart_config_regeneration", "label": "Smart Config Regeneration (previousConfigs snapshots)", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Baseline config snapshots shipped in the jar let migration diff and apply only what changed, preserving server/user customizations that previous migrations could discard in edge cases."}, {"id": "patch_notes_patch_notes_v2_1_1_radial_x_menu", "label": "Radial X Utility Menu Rework", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Utility menu reorganized as a radial wheel with grouped form nodes and an addon API for registering custom buttons, reducing clutter for races with large transformation pools."}, {"id": "patch_notes_patch_notes_v2_1_1_mob_battle_power_helper", "label": "MobBattlePowerHelper (Accurate Mob BP Formula)", "file_type": "concept", "source_file": "PATCH_NOTES/PATCH_NOTES-v2.1.1.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Non-DMZ mobs get BP computed from real entity attributes instead of the naive health + attack*5 estimate that grossly underestimated modded enemies; skipped for DMZ-managed entities and disableable via accurateMobBattlePower."}], "edges": [{"source": "patch_notes_patch_notes_v2_1_1_adaptive_defense_mitigation", "target": "patch_notes_patch_notes_v2_1_1_defense_system_rework", "relation": "references", "confidence