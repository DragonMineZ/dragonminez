{"nodes": [{"id": "ai_context_overview", "label": "DragonMineZ AI Context", "file_type": "document", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_context_boot_path", "label": "Mod Boot Path (DragonMineZ entry class)", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Entry constructor enforces the hard-incompatibility list (Legendary Tooltips, Epic Fight, Better Combat) before any init to fail fast with a clear IllegalStateException."}, {"id": "ai_context_dmzcommon_init", "label": "DMZCommon.init Central Registration", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_context_forgecommonevents_lifecycle", "label": "ForgeCommonEvents Server Lifecycle", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_context_statsdata_capability", "label": "StatsData Player Capability", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The 13 NBT keys written by save() are the save-format contract for all three storage backends; renaming any silently orphans existing NBT/JSON/DB data. load() hard-throws without PlayerQuestData, so it is a full-document loader, not a safe partial merge."}, {"id": "ai_context_sync_packets", "label": "Stats Sync Packets (StatsSyncS2C family)", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_context_packet_ordering", "label": "Packet Registration Order Defines Wire IDs", "file_type": "rationale", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Packet ids come from a sequential counter, so registration order is the wire protocol; new packets must be appended, never inserted mid-list, or client/server builds desync."}, {"id": "ai_context_config_versioning", "label": "Semver Config Versioning", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Version is a semver string because legacy numeric versions collide as doubles (21.10 == 21.1); outdated/corrupt defaults are moved to oldBackup and regenerated rather than overwritten."}, {"id": "ai_context_three_way_merge", "label": "Three-Way Config Merge Against previousConfigs Baselines", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Diffing user config against the previous release's bundled defaults lets balance changes propagate when the user kept defaults while preserving deliberate user edits; skipping the per-release baseline copy silently weakens the merge."}, {"id": "ai_context_quest_registry", "label": "Quest Registry World-Save Loading", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Existing world quest files are never overwritten by defaults, so changing default quest content in code has no effect on existing worlds unless files are deleted; this protects server-owner customizations."}, {"id": "ai_context_reward_difficulty", "label": "Quest Reward Difficulty Allow-Set", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Each reward carries an EnumSet of difficulties as an explicit allow-set (not a minimum threshold) so combinations like [EASY,HARD] are expressible; the old hard:/normal: type-string prefix was removed."}, {"id": "ai_context_wish_dragonball_pipeline", "label": "Wish and Dragonball Pipelines", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "There is no in-jar datapack wish JSON: reload listeners ignore scanned datapack JSON and delegate to DragonBallPackManager.loadAll; addon packs cannot introduce new blocks at runtime because RegistryObject refs are copied from bootstrap only."}, {"id": "ai_context_spacepod_registry", "label": "Space Pod Destination Registry", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_context_storage_backends", "label": "Storage Backends (NBT/JSON/DATABASE)", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Vanilla .dat capability persistence is always on; JSON/DATABASE double-persist on top with async login load overwriting vanilla values. On DB failure there is no fallback switch - durability comes only from the vanilla path."}, {"id": "ai_context_tick_handler_split", "label": "Three-Way Player Tick Split", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_context_worldgen_dimensions", "label": "Worldgen and Custom Dimensions", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "ai_context_commands_permissions", "label": "Commands and DMZPermissions", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "hasPermission() contains a hard-coded name-based admin bypass for three developer usernames - flagged as a pattern not to replicate."}, {"id": "ai_context_beta_access", "label": "Beta Access Verification Flow", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The dragonminez-ai bot flow is intentionally a narrow verification bridge (Discord OAuth to whitelist PR auto-approval), not a general public API."}, {"id": "ai_context_release_automation", "label": "CI and Release Automation Workflows", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Jar SHA-256 mismatch on publish is a warning, not a failure, because resource optimization is not byte-reproducible; the Discord bot never holds Modrinth/CurseForge tokens - those stay in GitHub Actions secrets."}, {"id": "ai_context_localization", "label": "Localization via Crowdin", "file_type": "concept", "source_file": "AI/Context.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "ai_context_boot_path", "target": "ai_context_dmzcommon_init", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_dmzcommon_init", "target": "ai_context_config_versioning", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_dmzcommon_init", "target": "ai_context_quest_registry", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_dmzcommon_init", "target": "ai_context_wish_dragonball_pipeline", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_dmzcommon_init", "target": "ai_context_packet_ordering", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_forgecommonevents_lifecycle", "target": "ai_context_storage_backends", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_forgecommonevents_lifecycle", "target": "ai_context_quest_registry", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_forgecommonevents_lifecycle", "target": "ai_context_wish_dragonball_pipeline", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_forgecommonevents_lifecycle", "target": "ai_context_spacepod_registry", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_forgecommonevents_lifecycle", "target": "ai_context_beta_access", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "AI/Context.md", "source_location": null, "weight": 1.0}, {"source": "ai_context_statsdata_capability", "target": "ai_context_sync_packets", "relation": "shares_data_with", "confidence": "EXTRAC